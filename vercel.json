{
    "builds": [
        {
            "src": "**/*.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "assets/**",
            "use": "@vercel/static"
        },
        {
            "src": "*.txt",
            "use": "@vercel/static"
        },
        {
            "src": "*.xml",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/",
            "dest": "/index.php"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}