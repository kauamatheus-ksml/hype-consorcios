# =============================================================
# SEGURANÇA DO SUBSYSTEM (CORRIGIDO)
# =============================================================

# 1. Segurança Básica
# Impede que alguém veja a lista de arquivos se digitar apenas o nome da pasta
Options -Indexes

# Ativar motor de reescrita (Necessário para substituir o <Directory>)
<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>

# =============================================================
# BLOQUEIO DE PASTAS SENSÍVEIS
# Usamos RewriteRule com a flag [F] (Forbidden/Proibido)
# Isso impede acesso via navegador, mas seus includes PHP continuam funcionando.
# =============================================================

<IfModule mod_rewrite.c>
    # Bloquear acesso total à pasta dev-tools
    RewriteRule ^dev-tools/.*$ - [F,L]

    # Bloquear acesso direto à pasta config (Protege as senhas, mas permite include)
    RewriteRule ^config/.*$ - [F,L]
</IfModule>

# =============================================================
# BLOQUEIO DE ARQUIVOS ESPECÍFICOS
# =============================================================

# Bloquear database.php
<Files "database.php">
    Require all denied
</Files>

# Bloquear arquivos de backup, logs e SQL dumps
<FilesMatch "\.(sql|json|bak|backup|log)$">
    Require all denied
</FilesMatch>

# =============================================================
# PERMISSÕES (PADRÃO)
# =============================================================

# OBS: Não é necessário criar regras <Allow> para "api", "components", 
# "classes" ou "includes". O Apache libera o acesso a eles automaticamente 
# se não houver regra de bloqueio.

# Garantir que scripts PHP normais sejam executáveis
<FilesMatch "\.php$">
    Require all granted
</FilesMatch>